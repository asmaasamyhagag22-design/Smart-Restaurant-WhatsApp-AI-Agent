# ────────────────────────────────────────────────────────────────────
#  Smart Restaurant WhatsApp AI Agent — environment template
#  Copy to `.env`.  Defaults below run FULLY LOCAL with no paid APIs.
#  To go to production, switch the *_provider values and fill the keys.
# ────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
ENV=local
DEBUG=true
HOST=0.0.0.0
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080

# ── Provider selection ───────────────────────────────────────────────
# memory|sql  — local demo uses in-memory repositories (no DB needed)
STORE_BACKEND=memory
# anthropic|mock  — mock answers deterministically without an API key
LLM_PROVIDER=mock
# memory|pgvector|pinecone
VECTOR_PROVIDER=memory
# local|whatsapp  — local = built-in web chat simulator
CHANNEL_PROVIDER=local
# mock|paymob|stripe
PSP_PROVIDER=mock
# mock|whisper_local|openai
STT_PROVIDER=mock
# mock|anthropic
VISION_PROVIDER=mock
# fastembed|hash|openai  (fastembed downloads a small ONNX model on first run)
EMBED_PROVIDER=fastembed

# ── LLM (set LLM_PROVIDER=anthropic to use these) ────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
INTENT_MODEL=claude-haiku-4-5-20251001
PLAN_MODEL=claude-sonnet-4-6
REFLECT_MODEL=claude-sonnet-4-6
VISION_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

# ── Embeddings ───────────────────────────────────────────────────────
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBED_DIM=384

# ── Database (only when STORE_BACKEND=sql) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://restaurant:restaurant@localhost:5432/restaurant
DB_ECHO=false

# ── Redis (optional; leave blank for in-memory cache) ────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Celery (local: run tasks inline) ─────────────────────────────────
CELERY_TASK_ALWAYS_EAGER=true
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── WhatsApp / Meta Cloud API (CHANNEL_PROVIDER=whatsapp) ────────────
WA_VERIFY_TOKEN=dev-verify-token
# WA_APP_SECRET=
# WA_ACCESS_TOKEN=
# WA_PHONE_NUMBER_ID=
WA_API_VERSION=v17.0

# ── Payment providers (PSP_PROVIDER=paymob|stripe) ───────────────────
# PAYMOB_API_KEY=
# PAYMOB_HMAC_SECRET=
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Agent behaviour ──────────────────────────────────────────────────
MAX_HOPS=8
HISTORY_SUMMARY_AFTER=6
DEFAULT_LANG=ar-EG

# ── Observability (optional) ─────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Security / multi-tenancy ─────────────────────────────────────────
ADMIN_JWT_SECRET=dev-admin-secret-change-me
DEFAULT_TENANT_SLUG=zaffran
